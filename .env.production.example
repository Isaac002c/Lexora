NODE_ENV=production
API_PORT=3333
WEB_URL=https://app.example.com
INTERNAL_API_URL=https://api.example.com
DATABASE_URL=postgresql://chronostek_app:URL_ENCODED_PASSWORD@postgres:5432/chronostek?schema=public
MIGRATION_DATABASE_URL=postgresql://chronostek_owner:URL_ENCODED_PASSWORD@postgres:5432/chronostek?schema=public
POSTGRES_DB=chronostek
POSTGRES_USER=chronostek_owner
POSTGRES_PASSWORD=replace-owner-password
POSTGRES_APP_PASSWORD=replace-app-password
SESSION_SECRET=replace-with-64-random-characters
FIELD_ENCRYPTION_KEY=replace-with-an-independent-64-character-secret
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/data/uploads
MAX_UPLOAD_SIZE_MB=20
LOG_LEVEL=info
API_DOMAIN=api.example.com
COOKIE_SECURE=true
