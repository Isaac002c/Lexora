NODE_ENV=development
WEB_PORT=3000
API_PORT=3333
WEB_URL=http://localhost:3000
API_URL=http://localhost:3333
INTERNAL_API_URL=http://localhost:3333
DATABASE_URL=postgresql://chronostek:chronostek@localhost:5432/chronostek?schema=public
SESSION_SECRET=replace-with-at-least-32-random-characters
FIELD_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads
MAX_UPLOAD_SIZE_MB=20
LOG_LEVEL=info
COOKIE_SECURE=false
